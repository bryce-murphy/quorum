{
  "schema": "quorum.policy/v1",
  "default_floor": "T0",
  "rules": [
    { "glob": ".github/workflows/**", "floor": "T3" },
    { "glob": ".quorum/policy.json", "floor": "T3" },
    { "glob": "packages/gate-action/**", "floor": "T3" },
    { "glob": "**/schemas/**", "floor": "T3" },
    { "glob": "schemas/**", "floor": "T3" },
    { "glob": "**/package-lock.json", "floor": "T3" },
    { "glob": "**/pnpm-lock.yaml", "floor": "T3" },
    { "glob": "**/migrations/**", "floor": "T3" },
    { "glob": "**/*.sql", "floor": "T3" },
    { "glob": "**/CLAUDE.md",                    "floor": "T3" },
    { "glob": "**/CLAUDE.local.md",              "floor": "T3" },
    { "glob": "**/.claude",                      "floor": "T3" },
    { "glob": "**/.claude/**",                   "floor": "T3" },
    { "glob": "**/AGENTS.md",                    "floor": "T3" },
    { "glob": "**/AGENTS.override.md",           "floor": "T3" },
    { "glob": "**/.codex",                       "floor": "T3" },
    { "glob": "**/.codex/**",                    "floor": "T3" },
    { "glob": "**/.agents",                      "floor": "T3" },
    { "glob": "**/.agents/skills",               "floor": "T3" },
    { "glob": "**/.agents/skills/**",            "floor": "T3" },
    { "glob": "**/.mcp.json",                    "floor": "T3" },
    { "glob": "**/.vscode",                      "floor": "T3" },
    { "glob": "**/.vscode/mcp.json",             "floor": "T3" },
    { "glob": ".github/copilot-instructions.md", "floor": "T3" },
    { "glob": "**/*.agent.md",                   "floor": "T3" },
    { "glob": "**/*.instructions.md",            "floor": "T3" },
    { "glob": ".github",                         "floor": "T3" },
    { "glob": ".github/agents",                  "floor": "T3" },
    { "glob": ".github/instructions",            "floor": "T3" },
    { "glob": "**/.cursor",                      "floor": "T3" },
    { "glob": "**/.cursor/**",                   "floor": "T3" },
    { "glob": "**/.cursorrules",                 "floor": "T3" },
    { "glob": "**/.cursorignore",                "floor": "T3" }
  ],
  "exempt_paths": [
    ".quorum/claims/**"
  ]
}
