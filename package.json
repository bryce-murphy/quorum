{
  "name": "quorum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic verification gate for multi-agent software delivery.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @quorum/contracts && npm run build -w @quorum/kernel",
    "gen:schemas": "npm run gen:schemas -w @quorum/contracts",
    "test": "vitest run",
    "drift": "vitest run contracts/test/drift",
    "quorum": "node packages/kernel/dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
