{
  "$ref": "#/definitions/Ledger",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Ledger": {
      "additionalProperties": false,
      "properties": {
        "counts": {
          "additionalProperties": false,
          "properties": {
            "failed": {
              "minimum": 0,
              "type": "integer"
            },
            "total": {
              "minimum": 0,
              "type": "integer"
            },
            "unverifiable_disclosed": {
              "minimum": 0,
              "type": "integer"
            },
            "verified": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "total",
            "verified",
            "failed",
            "unverifiable_disclosed"
          ],
          "type": "object"
        },
        "head": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "strict",
            "salvage"
          ],
          "type": "string"
        },
        "results": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "claim_id": {
                "type": "string"
              },
              "evidence": {
                "additionalProperties": {},
                "type": "object"
              },
              "status": {
                "enum": [
                  "verified",
                  "failed",
                  "unverifiable_disclosed"
                ],
                "type": "string"
              },
              "type": {
                "enum": [
                  "file_created",
                  "file_modified",
                  "file_deleted",
                  "commit_pushed",
                  "pr_opened",
                  "issue_filed",
                  "review_posted",
                  "test_passed"
                ],
                "type": "string"
              }
            },
            "required": [
              "claim_id",
              "type",
              "status",
              "evidence"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "schema": {
          "const": "quorum.ledger/v1",
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "tier_effective": {
          "enum": [
            "T0",
            "T1",
            "T2",
            "T3",
            "T4"
          ],
          "type": "string"
        },
        "verdict": {
          "enum": [
            "pass",
            "fail"
          ],
          "type": "string"
        }
      },
      "required": [
        "schema",
        "task",
        "head",
        "mode",
        "results",
        "counts",
        "tier_effective",
        "verdict"
      ],
      "type": "object"
    }
  }
}
