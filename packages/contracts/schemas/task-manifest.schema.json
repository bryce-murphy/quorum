{
  "$ref": "#/definitions/TaskManifest",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TaskManifest": {
      "additionalProperties": false,
      "properties": {
        "acceptance": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "agents": {
          "additionalProperties": {
            "minLength": 1,
            "type": "string"
          },
          "propertyNames": {
            "minLength": 1
          },
          "type": "object"
        },
        "branch": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "schema": {
          "const": "quorum.task/v1",
          "type": "string"
        },
        "state": {
          "enum": [
            "planned",
            "in_progress",
            "handed_back",
            "verified",
            "merged",
            "blocked"
          ],
          "type": "string"
        },
        "tier_effective": {
          "anyOf": [
            {
              "enum": [
                "T0",
                "T1",
                "T2",
                "T3",
                "T4"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "tier_proposed": {
          "enum": [
            "T0",
            "T1",
            "T2",
            "T3",
            "T4"
          ],
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema",
        "id",
        "title",
        "tier_proposed",
        "tier_effective",
        "acceptance",
        "branch",
        "state",
        "agents"
      ],
      "type": "object"
    }
  }
}
